<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PM / SaaS フィード</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    html { scroll-behavior: smooth; }
    .card:hover { transform: translateY(-2px); }
  </style>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen">

  <!-- ヘッダー & ナビ -->
  <header class="bg-white border-b border-gray-200 sticky top-0 z-10 shadow-sm">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between flex-wrap gap-2">
      <span class="font-bold text-lg text-gray-700">PM / SaaS フィード</span>
      <nav class="flex flex-wrap gap-2">
        {% for cat in categories %}
        <a href="#cat-{{ loop.index }}"
           class="text-sm px-3 py-1 rounded-full bg-{{ cat.color }}-100 text-{{ cat.color }}-700 hover:bg-{{ cat.color }}-200 transition-colors">
          {{ cat.name }}
        </a>
        {% endfor %}
      </nav>
    </div>
  </header>

  <main class="max-w-5xl mx-auto px-4 py-8 space-y-12">

    {% for cat in categories %}
    <section id="cat-{{ loop.index }}">

      <!-- カテゴリ見出し -->
      <h2 class="text-xl font-bold mb-4 pb-2 border-b-2 border-{{ cat.color }}-400 text-{{ cat.color }}-700">
        {{ cat.name }}
      </h2>

      {% for feed in cat.feeds %}
      <!-- フィード名 -->
      <div class="mb-6">
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">
          {{ feed.name }}
        </h3>

        {% if feed.entries %}
        <div class="grid gap-3 sm:grid-cols-2">
          {% for entry in feed.entries %}
          <a href="{{ entry.link }}" target="_blank" rel="noopener noreferrer"
             class="card bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md transition-all duration-200 block">
            <p class="text-sm font-semibold text-gray-800 leading-snug line-clamp-2 mb-2">
              {{ entry.title }}
            </p>
            {% if entry.summary %}
            <p class="text-xs text-gray-500 line-clamp-2 mb-2">{{ entry.summary }}</p>
            {% endif %}
            <div class="flex items-center justify-between mt-auto">
              <span class="text-xs px-2 py-0.5 rounded-full bg-{{ cat.color }}-50 text-{{ cat.color }}-600 font-medium">
                {{ feed.name }}
              </span>
              {% if entry.date %}
              <span class="text-xs text-gray-400">{{ entry.date }}</span>
              {% endif %}
            </div>
          </a>
          {% endfor %}
        </div>
        {% else %}
        <p class="text-sm text-gray-400">記事を取得できませんでした。</p>
        {% endif %}

      </div>
      {% endfor %}

    </section>
    {% endfor %}

  </main>

  <footer class="text-center text-xs text-gray-400 py-6 border-t border-gray-200 mt-8">
    最終更新: {{ updated_at }}
  </footer>

</body>
</html>
