# ============================================================
# ロリポップ FTP 設定 — GitHub Secrets に登録する値の一覧
# ============================================================
# このファイル自体には実際の値を書かないでください。
# GitHub の Settings → Secrets and variables → Actions で
# 下記の「キー名」と「値」を1つずつ登録してください。
# ============================================================

# FTPサーバーのホスト名
# ロリポップ管理画面 → サーバー情報 → FTPサーバー に記載
# 例: ftp.lolipop.jp
FTP_SERVER=

# FTPアカウント名
# ロリポップ管理画面 → サーバー情報 → ユーザー名 に記載
# 例: abc1234.lolipop.jp-your-name
FTP_USERNAME=

# FTPパスワード
# ロリポップ管理画面で設定したパスワード
FTP_PASSWORD=

# アップロード先のディレクトリ（ロリポップサーバー上のパス）
# 末尾のスラッシュは必須
# 例: /public_html/              ← ドメイン直下に置く場合
# 例: /public_html/feed/         ← /feed/ というサブディレクトリに置く場合
FTP_SERVER_DIR=
